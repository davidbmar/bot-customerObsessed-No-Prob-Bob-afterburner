# Server port
PORT=1203

# LLM provider (auto-detects: Claude > OpenAI > Ollama)
LLM_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama settings
OLLAMA_MODEL=qwen3:4b
OLLAMA_URL=http://localhost:11434

# Google Sign-In (optional — enables per-user accounts)
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# Comma-separated email allowlist (empty = allow all verified Google emails)
ALLOWED_EMAILS=

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
