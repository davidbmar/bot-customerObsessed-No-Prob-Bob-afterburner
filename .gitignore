# Sprint ephemeral files
.agent-done-*
.sprint-test-output.txt
.sprint-timing.txt

# Terraform — never commit provider binaries or local state
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Node
node_modules/

# Python
.venv/
__pycache__/
*.egg-info/
dist/
build/
*.pyc
.env

# Voice models (downloaded at runtime)
models/

# SQLite database
data/*.db
data/*.db-wal
data/*.db-shm

# Server logs
logs/

# Cloudflare tunnel config (contains tunnel ID)
.tunnel-config
